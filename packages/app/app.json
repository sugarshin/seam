{
  "expo": {
    "name": "Seam",
    "slug": "seam",
    "version": "0.12.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "seam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sugarshin.seam",
      "buildNumber": "23"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-image-picker",
      "expo-secure-store",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
